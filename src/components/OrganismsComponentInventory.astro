                {
                  label: "Forum italia",
                  ariaLabel: "link",
                  icon: "it-designers-italia",
                  linkTo: "#",
                },
                {
                  label: "Slack",
                  ariaLabel: "link",
                  icon: "it-slack",
                  linkTo: "#",
                },
                {
                  label: "Github",
                  ariaLabel: "link",
                  icon: "it-github",
                  linkTo: "#",
                },
              ],
