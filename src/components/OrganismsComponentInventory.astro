---
import {
  accordionItems,
  breadcrumbItems,
  cardItems,
  channelItems,
  dataStatisticsItems,
  image,
  listItems,
  menuItems,
  sidebarItems,
  useCaseItems,
} from "@utils/mock";
import { Breadcrumb } from "@components/molecules/Breadcrumb";
import { DataSection } from "@components/organisms/DataSection";
import { FAQSection } from "@components/organisms/FAQSection";
import { Footer } from "@components/organisms/Footer";
import { Header } from "@components/organisms/Header";
import {
  Hero,
  HeroCompactImage,
  HeroFullHeightImage,
} from "@components/organisms/Hero";
import { Sidebar } from "@components/organisms/Sidebar";
import { SupportChannelsSection } from "@components/organisms/SupportChannelsSection";
import { SupportCTASection } from "@components/organisms/SupportCTASection";
import { TextAndAccordions } from "@components/organisms/TextAndAccordions";
import { TextAndImage } from "@components/organisms/TextAndImage";
import { TextAndStatistics } from "@components/organisms/TextAndStatistics";
import { TextAndUseCase } from "@components/organisms/TextAndUseCase";
import { NewsFeed } from "@components/organisms/NewsFeed";
---

<h2 class="mb-4">Organisms</h2>

<table class="table table-bordered">
  <thead>
    <tr>
      <th>Data section</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td class="p-0">
        <DataSection
          highlights={{
            title: "Risultati raggiunti ",
            paragraph:
              "L’adozione del Cloud nella Pubblica Amministrazione è in costante crescita. Attraverso i progetti finanziati dal PNRR e le iniziative locali, ogni regione sta contribuendo alla modernizzazione dei servizi pubblici digitali.",
            image: image,
            cards: [
              {
                title:
                  "PA e enti pubblici che hanno già avviato la migrazione al cloud",
                description: "70.000 +",
              },
              {
                title:
                  "PA e enti pubblici che hanno già avviato la migrazione al cloud",
                description: "70.000 +",
              },
              {
                title:
                  "PA e enti pubblici che hanno già avviato la migrazione al cloud",
                description: "70.000 +",
              },
            ],
          }}
          panel={{
            title: "Distribuzione dei progetti sul territorio",
            paragraph: "Il numero di progetti Cloud divisi per regione.",
          }}
          result={{
            items: listItems,
            title: "L’esperienza delle regioni ",
            label: "in evidenza",
            paragraph:
              "Alcune regioni hanno sviluppato progetti cloud nella PA che offrono modelli operativi replicabili. Queste esperienze sono a disposizione di tutte le amministrazioni e contribuiscono a una diffusione più uniforme della Strategia Cloud Italia sul territorio.",
            news: [
              {
                linkTo: "#",
                title: "Nasce l’Innovation Hub di Polo Strategico Nazionale",
                description:
                  "Al via un ecosistema collaborativo per accelerare la trasformazione digitale della Pubblica Amministrazione",
                image: image,
              },
            ],
          }}
        />
      </td>
    </tr>
  </tbody>
</table>

<table class="table table-bordered">
  <thead>
    <tr>
      <th>FAQ section</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td class="p-0">
        <FAQSection
          title="Domande frequenti"
          accordion={{
            id: "FAQ",
            items: accordionItems,
            variant: "background-active",
          }}
        />
      </td>
    </tr>
  </tbody>
</table>

<table class="table table-bordered">
  <thead>
    <tr>
      <th>Footer</th>
    </tr>
  </thead>
