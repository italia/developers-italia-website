---
import { Badge } from "@components/atoms/Badge";
import { Button, ButtonLink } from "@components/atoms/Button";

type Props = {
  title: string;
  paragraph: string;
  category?: string;
  cta: {
    label: string;
    url: string;
  };
  labelButton: string;
};

const { title, paragraph, category, cta, labelButton } = Astro.props;
---

<style>
  @import "./style.scss";
</style>

<article class="it-card rounded shadow border p-5">
  <div class="row justify-content-between align-items-top mb-5">
    <div class="col-6">
      <h2>{title}</h2>
      {category && <Badge variant="primary" label={category} />}
    </div>
    <div class="col-6 text-end">
      <ButtonLink
        download
        linkTo={cta.url}
        label={cta.label}
        icon="it-download"
      />
    </div>
  </div>
  <div
    id="content-body"
    class="it-card-body p-0 content-collapsed font-serif"
    set:html={paragraph}
  />
  <div class="it-card-footer border-0 m-auto" aria-label="Espandi">
    <Button
      id="toggle-btn"
      label={labelButton}
      variant="link"
      size="small"
      icon="it-plus"
    />
  </div>

  <script>
    function setupReadMore() {
      const btn = document.getElementById("toggle-btn");
      const content = document.getElementById("content-body");

      if (btn && content) {
        btn.addEventListener("click", () => {
          const isExpanded = content.classList.contains("content-expanded");

          if (!isExpanded) {
            content.classList.remove("content-collapsed");
            content.classList.add("content-expanded");
            btn.classList.add("d-none");
          }
        });
      }
    }

    setupReadMore();
    document.addEventListener("astro:page-load", setupReadMore);
  </script>
</article>
