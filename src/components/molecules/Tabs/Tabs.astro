---
import TabsItem from "./TabsItem.astro";
import type { TabsProps } from "./types";
type Props = TabsProps;
const { id, items, variant = "light" } = Astro.props;

const hasMultipleTabs = items.length > 1;
---

<style>
  @import "./style.scss";
</style>
{
  hasMultipleTabs && (
    <ul
      class={`nav nav-tabs auto mb-5 ${variant === "dark" ? "bg-primary" : ""}`}
      id={`tabs-${id}`}
      role="tablist"
    >
      {items.map((item) => (
        <TabsItem {...item} />
      ))}
    </ul>
  )
}
<div
  class="tab-content"
  id=`tabs-${id}-content`
  role={hasMultipleTabs ? "presentation" : undefined}
>
  <slot />
</div>
