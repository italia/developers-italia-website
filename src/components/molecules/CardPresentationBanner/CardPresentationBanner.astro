<article
  class="it-card it-card-banner it-card-inline it-card-height-full bg-transparent"
>
  <div class="it-card-inline-content">
    <div class="it-card-body">
      <Fragment class="fs-5" set:html={description} />
      <Link label={title} url={linkTo} />
    </div>
  </div>
  <div class="it-card-banner-icon-wrapper">
    <Icon icon={icon} className="text-primary icon-xl" />
  </div>
</article>
