---
import ItExternalLink from "@static/assets/ItExternalLink.astro";
import type { LinkProps } from "./types";

type Props = LinkProps;

const {
  label,
  titleIcon,
  linkTo,
  url,
  disabled,
  openInNewTab = false,
  iconPosition = "right",
} = Astro.props;

const finalHref = url || linkTo || "#";
const ariaDisabled = disabled ? "true" : "false";
const target = openInNewTab ? "_blank" : "_self";
const rel = openInNewTab ? "noopener noreferrer" : "";
---

<a
  href={finalHref}
  aria-disabled={ariaDisabled}
  target={target}
  rel={rel}
  class={`d-inline-flex align-items-center gap-2 ${iconPosition === "left" ? "flex-row-reverse" : ""}`}
>
  <span class="fw-semibold">{label}</span>
  {url && <ItExternalLink color="white" size="sm" title={titleIcon} />}
</a>
