---
import { CatalogueFeed } from "@components/organisms/CatalogueFeed";
import type { PageNewsTab } from "@components/organisms/CatalogueFeed/types";
import type { CatalogueFeedFragmentType } from "@graphql/fragment/sectionFragments";
import type { SectionBackground } from "@utils/background";

type Props = {
  block: CatalogueFeedFragmentType;
};

const { block } = Astro.props;

const tabs: PageNewsTab[] = block.tabs.map((tab) => ({
  title: tab.title,
  paragraph: tab.paragraph,
  filterTitle: tab.filterTitle,
  labelForAll: tab.labelForAll,
  newsPageTabType: tab.newsPageTabType,
  filterStory: tab.filterStory?.id || undefined,
  perPage: tab.elementPerPage || undefined,
}));
---

<CatalogueFeed
  id={block.id}
  tabs={tabs}
  background={block.backgroundColor as SectionBackground}
/>
