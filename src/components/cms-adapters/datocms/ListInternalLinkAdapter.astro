---
import { linkResolver } from "@utils/linkResolver";
import type { ListInternalLinkFragmentType } from "../../../graphql/commonFragments";
import { ListInternalLink } from "../../molecules/ListInternalLink";

type DatoRecord = ListInternalLinkFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord;
};

const { block } = Astro.props;
const { lang } = Astro.locals;
const links = block.links.map((link) => ({
  linkTo: linkResolver(link.linkTo.id, lang),
  label: link.label,
  icon: link.icon || undefined,
}));
---

<ListInternalLink links={links} />
