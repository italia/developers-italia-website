---
import { Breadcrumb } from "@components/molecules/Breadcrumb";
import { Hero } from "@components/organisms/Hero";
import type { HeroVariantProps } from "@components/organisms/Hero/types";
import type { HeroFragmentType } from "@graphql/fragment/sectionFragments";
import type { SectionBackgroundHero } from "@utils/background";
import { createBreadcrumb } from "@utils/createBreadcrumb";
import { getCtaFields } from "@utils/getCtaFields";

type Props = {
  block: HeroFragmentType;
};

const { block } = Astro.props;

const { recordId, lang } = Astro.locals;

const itemsBreadcrumb = createBreadcrumb(recordId, lang);

const variantTextColorBreadcrumb = () => {
  const variantOnBackgroundColor =
    block.backgroundColor === "lighter" || block.backgroundColor === "default"
      ? "light"
      : "dark";

  if (block.variant === "default" || block.variant === "small") {
    return block.backgroundImage ? "dark" : variantOnBackgroundColor;
  }

  return variantOnBackgroundColor;
};

const { labelButton, linkTo, openInNewTab } = getCtaFields(block.cta, lang);
---

<Hero
  title={block.title}
  paragraph={block.paragraph || undefined}
  image={block.backgroundImage || undefined}
  imageMobile={block.backgroundImageForMobile || undefined}
  showBreadcrumb={block.showBreadcrumb}
  variant={(block.variant || undefined) as HeroVariantProps}
  backgroundColor={(block.backgroundColor ||
    undefined) as SectionBackgroundHero}
  labelButton={labelButton}
  linkTo={linkTo}
  openInNewTab={openInNewTab}
>
  <Breadcrumb
    items={itemsBreadcrumb}
    slot="breadcrumb"
    variant={variantTextColorBreadcrumb()}
  />
</Hero>
