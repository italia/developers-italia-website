---
import type { RelatedArticleFragmentType } from "../../../graphql/commonFragments";
import ArticleNavigationAdapter from "./ArticleNavigationAdapter.astro";
import ArticleListAdapter from "./ArticleListAdapter.astro";

type DatoRecord = RelatedArticleFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord;
};

const { block } = Astro.props;
---

{
  (() => {
    switch (block.relatedBlock.componentName) {
      case "ArticleNavigationRecord":
        return <ArticleNavigationAdapter block={block.relatedBlock} />;
      case "ArticleListRecord":
        return <ArticleListAdapter block={block.relatedBlock} />;
      default:
        return;
    }
  })()
}
