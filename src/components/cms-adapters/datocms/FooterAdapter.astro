---
import type { LinkProps } from "@components/atoms/Link/types";
import { Footer } from "@components/organisms/Footer";
import type { FooterLogoProps } from "@components/organisms/Footer/types";
import type { FooterFragmentType } from "@graphql/sectionFragments";
import { linkResolver } from "@utils/linkResolver";

type Props = FooterFragmentType;

const {
  heading,
  organizations,
  topicTitle,
  topicLink,
  utilityTitle,
  utility,
  smallPrint,
} = Astro.props;

const { lang } = Astro.locals;

const logos: FooterLogoProps[] = organizations.map((org) => {
  return {
    mainLogo: org.mainLogo,
    brandLogo: org.brandLogo,
    label: org.label,
    linkTo: org.url,
  };
});

const topicItems = topicLink.map((link) => {
  return {
    label: link.label,
    visuallyHidden: "link",
    linkTo: linkResolver(link.linkTo.id, lang),
  };
});

const socialUtilities: LinkProps[] = utility
  .filter((util) => util.componentName === "SupportingBrandRecord")
  .map((util) => ({
    label: util.label,
    ariaLabel: "link",
    icon: util.brandLogo,
    url: util.url,
  }));

const linkUtilities: LinkProps[] = utility
  .filter((util) => util.componentName === "ExternalLinkRecord")
  .map((util) => ({
    label: util.label,
    ariaLabel: "link",
    icon: "it-external-link",
    url: util.url,
  }));

const smallPrints = smallPrint.map((link) => {
  const isExternal = link.componentName === "ExternalLinkRecord";
  const url = isExternal ? link.url : linkResolver(link.linkTo?.id, lang);

  return {
    label: link.label,
    [isExternal ? "url" : "linkTo"]: url,
  };
});
---

<Footer
  brand={{
    heading: heading,
    logos: logos,
  }}
  topics={{
    title: topicTitle,
    items: topicItems,
  }}
  utilities={[
    {
      title: utilityTitle,
      socialItems: socialUtilities,
      linkItems: linkUtilities,
    },
  ]}
  smallPrints={{
    labelVisualHidden: "Sezione link utili",
    links: smallPrints,
  }}
/>
