---
import type { NewsFeedFragmentType } from "@graphql/sectionFragments";
import { NewsFeed } from "@components/organisms/NewsFeed";
import { linkResolver } from "@utils/linkResolver";
import { mapNewsToCardEditorialNewsProps } from "@utils/mappers";

type Props = {
  block: NewsFeedFragmentType;
};

const { block } = Astro.props;
const { lang } = Astro.locals;
---

<NewsFeed
  id={block.id}
  title={block.title}
  paragraph={block.paragraph}
  tabs={block.tabs.map((tab) => {
    switch (tab.componentName) {
      case "NewsTabRecord":
        return {
          componentName: "CardEditorialNews",
          title: tab.title,
          news: tab.news.map((n) => mapNewsToCardEditorialNewsProps(n)),
        };

      case "StoryTabRecord":
        return {
          componentName: "CardEditorialInlineMini",
          title: tab.title,
          news: tab.news.map((n) => ({
            title: n.title,
            image: n.image,
            linkTo: linkResolver(n.id, lang),
            category: n.category,
            dateTime: n.dateOfPublication,
          })),
        };
    }
  })}
/>
