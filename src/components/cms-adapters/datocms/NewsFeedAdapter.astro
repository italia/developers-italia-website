---
import { NewsFeed } from "@components/organisms/NewsFeed";
import type { NewsFeedFragmentType } from "@graphql/fragment/sectionFragments";
import { DatoBlockModel } from "@utils/cmsMapper";
import { linkResolver } from "@utils/linkResolver";

type Props = {
  block: NewsFeedFragmentType;
};

const { block } = Astro.props;
const { lang } = Astro.locals;

const buttonLink =
  block.cta?.linkTo?.id !== undefined
    ? linkResolver(block.cta.linkTo.id, lang)
    : undefined;
const buttonLabel = block.cta?.label;
---

<NewsFeed
  id={block.id}
  title={block.title}
  paragraph={block.paragraph}
  labelButton={buttonLabel}
  linkTo={buttonLink}
  tabs={block.tabs.map((tab) => {
    switch (tab.componentName) {
      case DatoBlockModel.NewsTab:
        return {
          componentName: "CardEditorialNews",
          title: tab.title,
          news: tab.news.map((n) => {
            const link = n.allLinkLocales?.find(
              (t) => t.locale === lang,
            )?.value;
            return {
              id: n.id,
              title:
                n.allTitleLocales?.find((t) => t.locale === lang)?.value || "",
              description:
                n.allParagraphLocales?.find((t) => t.locale === lang)?.value ||
                "",
              image: n.image,
              linkTo: link || "#",
              category:
                n.allTopicLocales?.find((t) => t.locale === lang)?.value
                  .label || "",
              dateTime: n.publishedAt,
              action: link ? new URL(link).host : "",
            };
          }),
        };

      case DatoBlockModel.StoryTab:
        return {
          componentName: "CardEditorialInlineMini",
          title: tab.title,
          news: tab.news.map((n) => ({
            id: n.id,
            title:
              n.allTitleLocales?.find((t) => t.locale === lang)?.value || "",
            image: n.image,
            linkTo: linkResolver(n.id, lang),
            category:
              n.allTopicLocales?.find((t) => t.locale === lang)?.value.label ||
              "",
            dateTime: n.publishedAt,
          })),
        };

      default:
        return {
          componentName: "CardEditorialNews",
          title: tab.title,
          news: [],
        };
    }
  })}
/>
