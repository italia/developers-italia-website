---
import type {
  SupportCTASectionBackgroundProps,
  SupportCTASectionSizeProps,
} from "@components/organisms/SupportCTASection/types";
import type { SupportCTASectionFragmentType } from "@graphql/sectionFragments";
import { linkResolver } from "@utils/linkResolver";
import { SupportCTASection } from "../../organisms/SupportCTASection";

type DatoRecord = SupportCTASectionFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord | SupportCTASectionFragmentType;
  size?: SupportCTASectionSizeProps;
};

const { block, size = "small" } = Astro.props;
const { lang } = Astro.locals;

const getCtaFields = () => {
  const cta = block.cta;

  if (!cta) return { labelButton: undefined, linkTo: undefined };

  switch (cta.componentName) {
    case "ExternalLinkRecord":
      return {
        labelButton: cta.label,
        linkTo: cta.url,
      };
    case "InternalLinkRecord":
      return {
        labelButton: cta.label,
        linkTo: linkResolver(cta.linkTo?.id, lang),
      };
    default:
      return {
        labelButton: undefined,
        linkTo: undefined,
      };
  }
};

const { labelButton, linkTo } = getCtaFields();
---

<SupportCTASection
  title={block.title}
  paragraph={block.paragraph}
  image={block.image}
  size={size}
  background={block.backgroundColor as SupportCTASectionBackgroundProps}
  labelButton={labelButton}
  linkTo={linkTo}
/>
