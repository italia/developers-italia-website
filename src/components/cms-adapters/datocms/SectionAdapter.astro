---
import { SplitContent } from "@components/layout/SplitContent";
import type {
  SectionAlignItems,
  SectionBackground,
} from "@components/layout/SplitContent/SplitContent.astro";
import type { SectionFragmentType } from "@graphql/sectionFragments";
import AccordionAdapter from "@components/cms-adapters/datocms/AccordionAdapter.astro";
import ImageContainerAdapter from "@components/cms-adapters/datocms/ImageContainerAdapter.astro";
import StatisticAdapter from "@components/cms-adapters/datocms/StatisticAdapter.astro";
import UseCasesAdapter from "@components/cms-adapters/datocms/UseCasesAdapter.astro";
import { AdditionalContent } from "@components/organisms/AdditionalContent";
import FeatureListAdapter from "@components/cms-adapters/datocms/FeatureListAdapter.astro";
import TextContainerAdapter from "@components/cms-adapters/datocms/TextContainerAdapter.astro";
import IconListAdapter from "@components/cms-adapters/datocms/IconListAdapter.astro";
import QuickLinkCardAdapter from "@components/cms-adapters/datocms/QuickLinkCardAdapter.astro";
import AuthorListAdapter from "@components/cms-adapters/datocms/AuthorListAdapter.astro";

type Props = {
  block: SectionFragmentType;
};

const { block } = Astro.props;

const additionalContent = block.additionalContent;
const leftBlock = block.left;
const rightBlock = block.right;

const variantTextContainer =
  block.background === "dark"
    ? "dark"
    : block.background === "primary"
      ? "primary"
      : "light";

const variantAdditionalContent =
  block.background === "dark" || block.background === "primary"
    ? "light"
    : undefined;
---

<SplitContent
  leftColumns={block.columnLeftSize}
  rightColumns={block.columnRightSize}
  alignItems={block.alignItems as SectionAlignItems}
  background={block.background as SectionBackground}
>
  <Fragment slot="left">
    {
      (() => {
        switch (leftBlock.componentName) {
          case "TextBlockRecord":
            return (
              <TextContainerAdapter
                block={leftBlock}
                variant={variantTextContainer}
              />
            );
          case "FeatureListBlockRecord":
            return <FeatureListAdapter block={leftBlock} />;
          default:
            return;
        }
      })()
    }
  </Fragment>

  <Fragment slot="right">
    {
      (() => {
        switch (rightBlock.componentName) {
          case "UseCaseBlockRecord":
            return <UseCasesAdapter block={rightBlock} />;
          case "ImageBlockRecord":
            return <ImageContainerAdapter block={rightBlock} />;
          case "StatisticBlockRecord":
            return <StatisticAdapter block={rightBlock} />;
          case "AccordionBlockRecord":
            return <AccordionAdapter block={rightBlock} />;
          case "IconListBlockRecord":
            return <IconListAdapter block={rightBlock} />;
          case "QuickLinkCardRecord":
            return <QuickLinkCardAdapter block={rightBlock} />;
          case "AuthorListRecord":
            return <AuthorListAdapter block={rightBlock} />;
          default:
            return;
        }
      })()
    }
  </Fragment>

  {
    additionalContent && (
      <AdditionalContent
        variant={variantAdditionalContent}
        content={additionalContent.content}
        title={additionalContent.title || undefined}
      />
    )
  }
</SplitContent>
