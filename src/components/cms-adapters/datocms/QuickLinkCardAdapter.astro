---
import type { ListLinkItemProps } from "@components/molecules/ListLink/types";
import { QuickLinkCard } from "@components/molecules/QuickLinkCard";
import type { QuickLinkCardFragmentType } from "@graphql/fragment/commonFragments";
import { getGlobalSettings } from "@lib/dataFetcher";
import { createDownloadUrl } from "@utils/createDownloadUrl";
import { linkResolver } from "@utils/linkResolver";

type DatoRecord = QuickLinkCardFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord | QuickLinkCardFragmentType;
};

const { block } = Astro.props;
const { lang } = Astro.locals;

const globalSetting = await getGlobalSettings(lang);

const downloadLabel = globalSetting?.ariaLabelDownloadLink || "Scarica il file";
const externalLinkLabel =
  globalSetting?.ariaLabelExternalLink || "Apri in una nuova scheda";
const articleLinkLabel =
  globalSetting?.ariaLabelInternalLink || "Leggi l'articolo";

const links: ListLinkItemProps[] = block.linkToResource.map((link) => {
  if (link.componentName === "ResourceRecord") {
    const res = link.allResourceLocales?.find((t) => t.locale === lang)?.value;

    if (res?.componentName === "DownloadLinkRecord") {
      return {
        linkTo: createDownloadUrl(res.doc),
        text: res.label,
        iconRight: "it-download",
        ariaLabelLink: `${downloadLabel} ${res.label}`,
      };
    }

    return {
      linkTo: res?.url || "#",
      text: res?.label || "",
      iconRight: "it-external-link",
      openInNewTab: true,
      ariaLabelLink: `${externalLinkLabel} ${res?.label || ""}`,
    };
  }

  if (link.componentName === "ArticleRecord") {
    return {
      linkTo: linkResolver(link.id, lang),
      text: link.title,
      iconRight: "it-arrow-right",
      ariaLabelLink: `${articleLinkLabel} ${link.title}`,
    };
  }

  return {
    linkTo: "#",
    text: "Link non valido",
  };
});
---

<QuickLinkCard title={block.title} links={links} />
