---
import TextContainerAdapter from "@components/cms-adapters/datocms/TextContainerAdapter.astro";
import { WebinarDescription } from "@components/organisms/WebinarDescription";
import type { WebinarDescriptionFragmentType } from "@graphql/fragment/sectionFragments";
import EventsListAdapter from "./EventsListAdapter.astro";
import LinksTagdAdapter from "./LinksTagdAdapter.astro";

type Props = {
  block: WebinarDescriptionFragmentType;
};
const { block } = Astro.props;
---

<WebinarDescription>
  <TextContainerAdapter slot="text" block={block.text} variant="light" />
  <EventsListAdapter slot="subjects" block={block.subjects} />

  {
    block.resources && (
      <LinksTagdAdapter slot="resources" block={block.resources} />
    )
  }
</WebinarDescription>
