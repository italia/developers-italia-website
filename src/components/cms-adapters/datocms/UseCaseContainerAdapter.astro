---
import { linkResolver } from "@utils/linkResolver";
import type { UseCaseContainerFragmentType } from "../../../graphql/sectionFragments";
import UseCaseContainer from "../../organisms/UseCaseContainer/UseCaseContainer.astro";
import type { UseCaseCardProps } from "@components/molecules/UseCaseCard/types";

type Props = {
  block: UseCaseContainerFragmentType;
};

const { block } = Astro.props;
const { lang } = Astro.locals;

const useCases: UseCaseCardProps[] = block.useCases.map((useCase) => {
  return {
    title: useCase.title,
    paragraph: useCase.paragraph || "",
    linkTo: linkResolver(useCase.id, lang),
    image: useCase.image || undefined,
    listTopics: {
      title: useCase.topics?.title || undefined,
      topics: useCase.topics?.topics.map((topic) => topic.label) || [],
    },
    descriptionTitle: useCase.descriptionTitle || undefined,
    description: useCase.description || undefined,
  };
});
---

<UseCaseContainer useCases={useCases} />
