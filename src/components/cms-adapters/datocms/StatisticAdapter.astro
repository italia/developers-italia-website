---
import type {
  DataContainerProps,
  VariantTextDataContainerProps,
} from "@components/molecules/DataContainer/types";
import { Statistics } from "@components/molecules/Statistics";
import type { StatisticBlockFragmentType } from "@graphql/commonFragments";

type Props = {
  block: StatisticBlockFragmentType;
  variant?: VariantTextDataContainerProps;
};

const { block, variant = "dark" } = Astro.props;

const items: DataContainerProps[] = block.statistics.map((item) => {
  return {
    info: item.info,
    title: item.title,
    contentIcon: item.iconSelect,
  };
});
---

<Statistics items={items} variant={variant} />
