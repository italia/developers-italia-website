---
import TextContainerAdapter from "@components/cms-adapters/datocms/TextContainerAdapter.astro";
import UseCasesAdapter from "@components/cms-adapters/datocms/UseCasesAdapter.astro";
import { TextAndUseCase } from "@components/organisms/TextAndUseCase";
import type { TextAndUseCasesFragmentType } from "@graphql/fragment/sectionFragments";
import type { SectionBackground } from "@utils/background";

type Props = {
  block: TextAndUseCasesFragmentType;
};

const { block } = Astro.props;

const variantCardContainer =
  block.backgroundColor === "default" ? "light" : "default";
---

<TextAndUseCase
  background={block.backgroundColor as SectionBackground}
  sectionTitleId={block.text.title}
>
  <TextContainerAdapter slot="text" block={block.text} variant="light" />
  <UseCasesAdapter
    slot="useCases"
    block={block.useCases}
    backgroundColor={variantCardContainer}
  />
</TextAndUseCase>
