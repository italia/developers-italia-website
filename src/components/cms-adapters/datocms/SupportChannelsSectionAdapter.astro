---
import { SupportChannelsSection } from "@components/organisms/SupportChannelsSection";
import type { SupportChannelSectionBackgroundProps } from "@components/organisms/SupportChannelsSection/types";
import type { SupportChannelsSectionFragmentType } from "@graphql/sectionFragments";

type Props = {
  block: SupportChannelsSectionFragmentType;
};

const { block } = Astro.props;

const channelItems = block.channels.map((channel) => {
  return {
    title: channel.title,
    description: channel.description,
    icon: channel.iconSelect,
    linkTo: channel.linkTo || "#",
  };
});
---

<SupportChannelsSection
  title={block.title}
  paragraph={block.paragraph}
  channels={channelItems}
  background={block.backgroundColor as SupportChannelSectionBackgroundProps}
/>
