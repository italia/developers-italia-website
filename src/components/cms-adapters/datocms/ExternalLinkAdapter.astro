---
import { CardService } from "@components/molecules/CardService";
import type { ExternalLinkFragmentType } from "@graphql/fragment/commonFragments";

type DatoRecord = ExternalLinkFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord;
};

const { block } = Astro.props;

if (!block.label || !block.url) {
  return null;
}
---

<CardService
  id={block.id}
  title={block.label}
  linkTo={block.url}
  description={block.description || ""}
/>
