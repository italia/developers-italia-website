---
import { Sidebar } from "@components/organisms/Sidebar";
import type { SidebarFragmentType } from "@graphql/commonFragments";
import { createMenuSidebar } from "@utils/createMenuSidebarHelper";

type Props = {
  sidebar: SidebarFragmentType;
};

const { sidebar } = Astro.props;
const currentPathname = Astro.url.pathname.replace(/\/$/, "");
const { lang } = Astro.locals;
const sidebarItems = createMenuSidebar(sidebar.menu, currentPathname, lang);
---

<Sidebar
  id={sidebar.id}
  header={sidebar.headerLabel || undefined}
  ariaLabel="Apri/chiudi sidebar"
  openLabel={sidebar.openLabel}
  closeLabel={sidebar.closeLabel}
  items={sidebarItems}
/>
