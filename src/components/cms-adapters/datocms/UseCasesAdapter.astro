---
import type {
  UseCaseCardBackgroundColor,
  UseCaseCardProps,
} from "@components/molecules/UseCaseCard/types";
import { UseCases } from "@components/molecules/UseCases";
import type { UseCaseBlockFragmentType } from "@graphql/fragment/commonFragments";
import { getLocaleValue } from "@utils/getLocaleValue";
import { linkResolver } from "@utils/linkResolver";

type Props = {
  block: UseCaseBlockFragmentType;
  backgroundColor?: UseCaseCardBackgroundColor;
};

const { block, backgroundColor = "light" } = Astro.props;
const { lang } = Astro.locals;

const usecases: UseCaseCardProps[] = block.useCases.map((usecase) => {
  const titleData =
    "allTitleLocales" in usecase
      ? usecase.allTitleLocales
      : usecase._allTitleLocales;

  let paragraphData =
    "_allParagraphLocales" in usecase
      ? usecase._allParagraphLocales
      : "_allAbstractLocales" in usecase
        ? usecase._allAbstractLocales
        : [];

  return {
    title: getLocaleValue(titleData, lang, ""),
    paragraph: getLocaleValue(paragraphData, lang, "") || "",
    linkTo: linkResolver(usecase.id, lang),
    image: usecase.image || undefined,
  };
});
---

<UseCases
  label={block.title}
  items={usecases}
  backgroundColor={backgroundColor}
/>
