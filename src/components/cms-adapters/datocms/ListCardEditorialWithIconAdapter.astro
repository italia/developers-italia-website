---
import { ListCardEditorialWithIcon } from "@components/molecules/ListCardEditorialWithIcon";
import type { ListCardEditorialWithIconFragmentType } from "@graphql/commonFragments";

type DatoRecord = ListCardEditorialWithIconFragmentType & {
  __typename: string;
  id: string;
};

type Props = {
  block: DatoRecord;
};

const { block } = Astro.props;

const cardsData = block?.items || [];
---

<ListCardEditorialWithIcon cards={cardsData} />
