---
import { linkResolver } from "@utils/linkResolver";
import type { DataSectionRecordFragmentType } from "../../../graphql/sectionFragments";
import { DataSection } from "../../organisms/DataSection";
import type { CardEditorialNewsProps } from "@components/molecules/CardEditorialNews/types";
import type { ResultProps } from "@components/organisms/DataSection/types";

type Props = {
  block: DataSectionRecordFragmentType;
};

const { block } = Astro.props;
const { lang } = Astro.locals;

const highlights = {
  ...block.highlights,
  image: block.highlights.image,
};
const panel = {
  title: block.panel.title,
  paragraph: block.panel.paragraph,
  chart: block.panel.chart,
  externalLink: {
    label: block.panel.externalLink.label,
    linkTo: block.panel.externalLink.url,
    externalLink: true,
    icon: block.panel.externalLink.icon || undefined,
    titleIcon: block.panel.externalLink.titleIcon || undefined,
  },
};

const newsResult: CardEditorialNewsProps[] = block.result.useCases.map(
  (useCase) => {
    return {
      title: useCase.title,
      description: useCase.paragraph || "",
      image: useCase.image || undefined,
      linkTo: linkResolver(useCase.id, lang),
    };
  },
);

const result: ResultProps = {
  title: block.result.title,
  paragraph: block.result.paragraph,
  news: newsResult,
  items: block.result.items.map((item) => ({
    title: item.title,
    paragraph: item.paragraph,
  })),
  titleListNews: block.result.titleListUseCases || undefined,
};
---

<DataSection
  highlights={highlights}
  panel={panel}
  result={{ ...result, news: newsResult }}
/>
