---
import { Header } from "@components/organisms/Header";
import type {
  HeaderFragmentType,
  SearchMenuFragmentType,
} from "@graphql/sectionFragments";
import { createMenu } from "@utils/createMenuHelper";
import { linkResolver } from "@utils/linkResolver";

type Props = HeaderFragmentType & {
  homeRecordId?: string;
  search?: SearchMenuFragmentType;
};

const {
  tagline,
  organization,
  siteName,
  mainNavigation,
  secondaryNavigation,
  locales,
  homeRecordId,
  logoSelect,
  search,
} = Astro.props;

const { lang } = Astro.locals;
const currentUrl = Astro.url.pathname;

const menuItems = createMenu(
  mainNavigation,
  secondaryNavigation,
  currentUrl,
  lang,
);
---

<Header
  brandTagLine={organization}
  brandTitle={siteName}
  slimContent={tagline}
  menuItems={menuItems}
  locales={locales}
  logo={logoSelect}
  search={search && {
    isEnabled: search.isSearchEnabled,
    label: search.searchLabel,
    url: linkResolver(search.id, lang),
  }}
  linkBackHome={linkResolver(homeRecordId, lang)}
/>
