---
import { Header } from "@components/organisms/Header";
import type { HeaderFragmentType } from "@graphql/fragment/layout";
import type { SearchMenuFragmentType } from "@graphql/fragment/sectionFragments";
import { createMenu } from "@utils/createMenuHelper";
import { linkResolver } from "@utils/linkResolver";

type Props = HeaderFragmentType & {
  homeRecordId?: string;
  search?: SearchMenuFragmentType;
};

const {
  _allTaglineLocales,
  _allOrganizationLocales,
  siteName,
  allMainNavigation,
  allSecondaryNavigation,
  locales,
  homeRecordId,
  logoSelect,
  search,
} = Astro.props;

const { lang } = Astro.locals;
const currentUrl = Astro.url.pathname;

const tagline = _allTaglineLocales?.find((l) => l.locale === lang)?.value;
const organization = _allOrganizationLocales?.find(
  (l) => l.locale === lang,
)?.value;
const mainNavigation = allMainNavigation?.find((l) => l.locale === lang)?.value;
const secondaryNavigation = allSecondaryNavigation?.find(
  (l) => l.locale === lang,
)?.value;

const menuItems = createMenu(
  mainNavigation,
  secondaryNavigation,
  currentUrl,
  lang,
);
---

<Header
  brandTagLine={tagline}
  brandTitle={siteName}
  slimContent={organization}
  menuItems={menuItems}
  locales={locales}
  logo={logoSelect}
  search={search && {
    isEnabled: search.isSearchEnabled,
    label: search._allSearchLabelLocales?.find((l) => l.locale === lang)?.value,
    url: linkResolver(search.id, lang),
  }}
  linkBackHome={linkResolver(homeRecordId, lang)}
/>
