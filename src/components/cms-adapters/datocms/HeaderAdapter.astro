---
import type { HeaderFragmentType } from "@graphql/sectionFragments";
import { createMenu } from "@utils/createMenuHelper";
import { Header } from "@components/organisms/Header";
import { linkResolver } from "@utils/linkResolver";

type Props = HeaderFragmentType & {
  homeRecordId?: string;
};

const {
  tagline,
  organization,
  siteName,
  mainNavigation,
  secondaryNavigation,
  locales,
  homeRecordId,
  logo,
} = Astro.props;

const { lang } = Astro.locals;
const currentUrl = Astro.url.pathname;

const menuItems = createMenu(
  mainNavigation,
  secondaryNavigation,
  currentUrl,
  lang,
);
---

<Header
  brandTagLine={organization}
  brandTitle={siteName}
  slimContent={tagline}
  menuItems={menuItems}
  locales={locales}
  logo={logo.url}
  linkBackHome={linkResolver(homeRecordId, lang)}
/>
