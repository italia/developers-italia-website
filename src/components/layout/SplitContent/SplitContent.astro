---
import { SectionContainer } from "@components/organisms/SectionContainer";
import { getSectionBgClass } from "@utils/background";
import type { SplitContentProps } from "./types";

type Props = SplitContentProps;

const {
  leftColumns = 6,
  rightColumns = 6,
  alignItems = "center",
  background = "default",
  classSecondColumn = "",
  sectionTitleId,
} = Astro.props;
---

<SectionContainer
  className={getSectionBgClass(background)}
  sectionTitleId={sectionTitleId}
>
  <div class=`row justify-content-between align-items-${alignItems}`>
    <div class=`col-lg-${leftColumns} col-12`>
      <slot name="left" />
    </div>
    <div
      class=`col-lg-${rightColumns} col-12 mt-4 mt-lg-0 ${classSecondColumn}`
    >
      <slot name="right" />
    </div>
  </div>
  <slot />
</SectionContainer>
