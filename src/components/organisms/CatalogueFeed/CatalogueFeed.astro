---
import type { CardEditorialStoryProps } from "@components/molecules/CardEditorialStory/types";
import { SplitContent } from "@components/layout/SplitContent";
import { TabContent, Tabs } from "@components/molecules/Tabs";
import { NewsArchiveList } from "@components/organisms/NewsArchiveList";
import { PaginatedCollection } from "@components/react/PaginatedCollection/PaginatedCollection";
import {
  getNews,
  getResources,
  getStories,
  getWebinars,
} from "@lib/dataFetcher";
import { isDraftModeEnabled } from "@lib/draftMode";
import {
  mapNewsToCardEditorialNewsProps,
  mapResourceToResourceProps,
  mapStoryToCardEditorialStoryProps,
  mapWebinarToCardEditorialNewsProps,
} from "@utils/mappers";
import { sortFeedItems } from "@utils/feedSort";
import { isNewsStoryClass } from "@utils/storyClassification";
import type { ElementType, UpdateTabSectionProps } from "./types";

type Props = UpdateTabSectionProps;

const { id, background = "default", tabs = [] } = Astro.props;
const { lang } = Astro.locals;

const tabsItems = tabs.map((tab, index) => ({
  id: `tab-${id}-${index}`,
  label: tab.title,
  active: index === 0,
  filterStory: tab.filterStory,
}));

const isPreview = isDraftModeEnabled(Astro.cookies);

const news = await getNews(isPreview);
const stories = await getStories(isPreview);
const webinars = await getWebinars(isPreview);
const resources = await getResources(isPreview);

function isValidTabType(val: string): val is ElementType {
  return (
    val === "news_item" ||
    val === "story_item" ||
    val === "webinar_item" ||
    val === "resource"
  );
}

function getFilteredItems(
  tabType: ElementType,
  tabCategoryReference?: string,
  sortMode?: string,
) {
  switch (tabType) {
    case "story_item":
      const filteredStoryByLang = stories.filter((s) =>
        s.data.allTitleLocales?.some((item) => item.locale === lang),
      );

      const filteredStories = tabCategoryReference
        ? filteredStoryByLang.filter(
            (s) => s.data.articleClassification?.id === tabCategoryReference,
          )
        : filteredStoryByLang;

      return sortFeedItems(
        filteredStories.map((s) =>
          mapStoryToCardEditorialStoryProps(s.data, lang),
        ),
        sortMode,
        lang,
      );

    case "news_item":
      const filteredNews = news.filter((n) =>
        n.data.allTitleLocales?.some((item) => item.locale === lang),
      );

      return sortFeedItems(
        filteredNews.map((n) => mapNewsToCardEditorialNewsProps(n.data, lang)),
        sortMode,
        lang,
      );

    case "webinar_item":
      const filteredWebinars = webinars.filter((w) =>
        w.data.allTitleLocales?.some((item) => item.locale === lang),
      );
      return sortFeedItems(
        filteredWebinars.map((w) =>
          mapWebinarToCardEditorialNewsProps(w.data, lang),
        ),
        sortMode,
        lang,
      );

    case "resource":
      return sortFeedItems(
        resources.map((r) => mapResourceToResourceProps(r.data, lang)),
        sortMode,
        lang,
      );
    default:
      return [];
  }
}

// La pagina Notizie è un CatalogueFeed con un unico tab story_item filtrato
// sulla classe "Notizie": in quel caso usiamo il layout a lista (NewsArchiveList)
// al posto della griglia con immagini. La discriminazione passa da
// `isNewsStoryClass` per essere pronta al futuro switch su `storyType`.
const newsArchiveTab =
  tabs.length === 1 &&
  tabs[0].newsPageTabType === "story_item" &&
  isNewsStoryClass(tabs[0].filterStory)
    ? tabs[0]
    : null;
---

{
  newsArchiveTab ? (
    <NewsArchiveList
      id={id}
      title={newsArchiveTab.title}
      items={
        getFilteredItems(
          "story_item",
          newsArchiveTab.filterStory,
          newsArchiveTab.sortMode,
        ) as CardEditorialStoryProps[]
      }
    />
  ) : (
    <SplitContent leftColumns={5} alignItems="top" background={background}>
      <div class="row">
        <Tabs id={id} items={tabsItems}>
          {tabs.map((tab, index) => {
            const tabType = tab.newsPageTabType;
            if (!isValidTabType(tabType)) return null;

            const items = getFilteredItems(
              tabType,
              tab.filterStory,
              tab.sortMode,
            );

            return (
              <TabContent tab={tabsItems[index]}>
                <PaginatedCollection
                  client:load
                  {...tab}
                  items={items as any}
                  newsPageTabType={tabType}
                  lang={lang}
                />
              </TabContent>
            );
          })}
        </Tabs>
      </div>
    </SplitContent>
  )
}
