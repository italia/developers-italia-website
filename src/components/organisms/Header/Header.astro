---
import HeaderCentral from "./HeaderCentral.astro";
import HeaderSlim from "./HeaderSlim.astro";
import SkipLinks from "./SkipLinks.astro";
import type { HeaderProps } from "./types";

type Props = HeaderProps;

const {
  brandList,
  locales,
  brandTitle,
  brandTagLine,
  menuItems,
  linkBackHome,
  logo,
  search,
  metaNav,
  variant = "light",
} = Astro.props;
---

<header
  class="it-header-wrapper it-header-sticky shadow-sm"
  data-bs-position-type="fixed"
  data-bs-sticky-class-name="is-sticky"
  data-bs-target="#header-nav-wrapper"
>
  <SkipLinks idMenu={menuItems.left[0].id} />

  <HeaderSlim
    brandList={brandList}
    linkBackHome={linkBackHome}
    locales={locales}
    metaNav={metaNav}
    variant={variant}
  />
  <HeaderCentral
    search={search}
    brandTitle={brandTitle}
    brandTagLine={brandTagLine}
    menuItems={menuItems}
    linkBackHome={linkBackHome}
    logo={logo}
    variant={variant}
  />
</header>
