---
import FooterBrand from "./FooterBrand.astro";
import FooterMain from "./FooterMain.astro";
import FooterSmallPrints from "./FooterSmallPrints.astro";
import type { FooterProps } from "./types";

type Props = FooterProps;

const { brand, utilities, topics, smallPrints, mailingListForm } = Astro.props;
---

<footer class="it-footer">
  <FooterBrand {...brand} />
  <FooterMain
    topics={topics}
    utilities={utilities}
    mailingListForm={mailingListForm}
  />
  <FooterSmallPrints {...smallPrints} />
</footer>
