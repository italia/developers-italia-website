---
import { Link } from "@components/atoms/Link";
import type { FooterSmallPrintsProps } from "./types";

type Props = FooterSmallPrintsProps;

const { labelVisualHidden, links } = Astro.props;
---

<div class="it-footer-small-prints clearfix">
  <div class="container">
    <p class="visually-hidden">{labelVisualHidden}</p>
    <ul
      class="it-footer-small-prints-list list-inline mb-0 d-flex flex-column flex-md-row px-0"
    >
      {
        links.map((link) => (
          <li class="list-inline-item d-flex align-items-center gap-2">
            <Link {...link} openInNewTab={true} isIcon={true} variant="dark" />
          </li>
        ))
      }
    </ul>
  </div>
</div>
