---
import { getGlobalSettings } from "@lib/dataFetcher";
import { generateJsonLdScripts } from "@utils/JsonLD/generateScripts";
import { type JsonLdPageData } from "@utils/JsonLD/seoJsonLd";

type Props = {
  jsonLd?: JsonLdPageData;
};

const { jsonLd } = Astro.props;

const { lang, recordId } = Astro.locals;

const siteUrl = Astro.site || process.env.SITE_URL || "";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const globalSetting = await getGlobalSettings(lang);

const siteName = globalSetting?.siteName || "Cloud Italia";

const jsonLdScripts = generateJsonLdScripts({
  jsonLd,
  lang,
  siteUrl,
  canonicalUrl,
  recordId,
  siteName,
});

const serializedJsonLdScripts = jsonLdScripts.map((script) =>
  JSON.stringify(script),
);
---

{
  serializedJsonLdScripts.map((payload) => (
    <script is:inline type="application/ld+json" set:html={payload} />
  ))
}
