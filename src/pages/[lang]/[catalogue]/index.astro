---
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import type { CatalogueContentFragmentType } from "@graphql/fragment/catalogue";
import type { TagFragmentType } from "@graphql/fragment/commonFragments";
import type { SeoFieldFragmentType } from "@graphql/fragment/seoFragments";
import {
  AllCataloguesContentQuery,
  CatalogueSeoQuery,
} from "@graphql/query/catalogue";

import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { getLastUpdateCollection } from "@utils/getLastUpdateCollection";
import {
  extractFaqItems,
  extractListItems,
  type JsonLdPageData,
} from "@utils/JsonLD/seoJsonLd";
import { linkResolver } from "@utils/linkResolver";
import { removeLang } from "@utils/pathHelper";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      catalogue: string;
      lang: SiteLocale;
    };
    props: {
      seoMeta: TagFragmentType[];
      seo: SeoFieldFragmentType | null;
      content: CatalogueContentFragmentType[];
      id: string;
      publishedAt: string;
      updatedAt: string;
    };
  };

  const response = await executeQuery(AllCataloguesContentQuery);

  const datesRegistry = {
    news_item: response.lastNews[0]?.publishedAt,
    story_item: response.lastStory[0]?.publishedAt,
    webinar_item: response.lastWebinar[0]?.publishedAt,
    resource: response.lastResourse[0]?.publishedAt,
  };

  const pathsPromises =
    response.allCatalogues?.flatMap((page) =>
      page.locales.map(async (lang) => {
        const content = page.allContentLocales?.find(
          (contentLocale) => contentLocale.locale === lang,
        )?.value;

        const finalUpdateDate = getLastUpdateCollection(content, datesRegistry);

        const seoRes = await executeQuery(CatalogueSeoQuery, {
          variables: { id: page.id, locale: lang },
        });

        const fullPath = linkResolver(page.id, lang);

        const slug = removeLang(fullPath, lang);

        return {
          params: {
            catalogue: slug,
            lang: lang,
          },
          props: {
            seoMeta: seoRes.catalogue?.metaTags || [],
            seo: seoRes.catalogue?.seo || null,
            id: page.id,
            content: content,
            publishedAt: finalUpdateDate,
            updatedAt: seoRes.catalogue?.updatedAt || page.updatedAt,
          },
        };
      }),
    ) || [];

  const paths = await Promise.all(pathsPromises);

  return paths.filter((path): path is PathItem => !!path.params.lang);
}

const { id, content, seo, seoMeta, publishedAt, updatedAt } = Astro.props;
const { lang } = Astro.params;

Astro.locals.lang = lang;
Astro.locals.recordId = id;

const jsonLd: JsonLdPageData = {
  pageType: ["collection", "list"],
  seo: seo || undefined,
  publishedAt,
  updatedAt,
  faq: extractFaqItems(content ?? []),
  listItems: extractListItems(
    content ?? [],
    Astro.site || process.env.SITE_URL || "",
    lang,
  ),
};
---

<Layout pageSeo={seoMeta} datePublished={publishedAt} jsonLd={jsonLd}>
  <PageAdapter content={content} />
</Layout>
