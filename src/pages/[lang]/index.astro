---
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { HomepageQuery, LocalesQuery } from "@utils/query";

export async function getStaticPaths() {
  const {
    site: { locales },
  } = await executeQuery(LocalesQuery);
  return locales.map((lang) => ({
    params: {
      lang,
    },
  }));
}

const { lang } = Astro.params;

const { homepage } = await executeQuery(HomepageQuery, {
  variables: { locale: lang },
});

if (!homepage) return;

const content = homepage.content;
Astro.locals.recordId = homepage.id;
---

<Layout pageSeo={homepage.seo} datePublished={homepage.publishedAt}>
  <PageAdapter content={content} />
</Layout>
