---
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import Layout from "@layouts/Layout.astro";
import { getLocaleValue } from "@utils/getLocaleValue";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const response = await getEntry("locales", "site-locales");

  const locales = response?.data.locales;
  if (!locales) throw new Error("Locales not found");
  return locales.map((lang) => ({
    params: {
      lang,
    },
  }));
}

const { lang } = Astro.params;
Astro.locals.lang = lang;

const response = await getCollection("homepage");

const homepage = response[0].data;
if (!homepage) return;

const seoResCollection = await getEntry("global_seo", `${homepage.id}_${lang}`);
const seoRes = seoResCollection?.data;

const content = getLocaleValue(homepage.allContentLocales, lang, null);

if (!content) return;

Astro.locals.recordId = homepage.id;
---

<Layout pageSeo={seoRes?.metaTags} datePublished={homepage.publishedAt}>
  <PageAdapter content={content} />
</Layout>
