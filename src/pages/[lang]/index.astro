---
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import type { HomepageModelContentFragmentType } from "@graphql/templateFragments";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { GlobalSettingsQuery, HomepageQuery, LocalesQuery } from "@utils/query";

export async function getStaticPaths() {
  const {
    site: { locales },
  } = await executeQuery(LocalesQuery);
  return locales.map((lang) => ({
    params: {
      lang,
    },
  }));
}

const { lang } = Astro.params;

const { homepage } = await executeQuery(HomepageQuery, {
  variables: { locale: lang },
});

const { globalSetting } = await executeQuery(GlobalSettingsQuery, {
  variables: { locale: lang },
});

const content = homepage?.content as HomepageModelContentFragmentType[];
---

<Layout locale={lang} pageSeo={homepage?.seo}>
  <PageAdapter content={content} sitename={globalSetting?.siteName || "Home"} />
</Layout>
