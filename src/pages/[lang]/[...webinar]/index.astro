---
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";
import { Breadcrumb } from "@components/molecules/Breadcrumb";
import type { TagFragmentType } from "@graphql/fragment/commonFragments";
import type { SeoFieldFragmentType } from "@graphql/fragment/seoFragments";
import type { WebinarContentFragmentType } from "@graphql/fragment/webinar";
import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { DatoBlockModel } from "@utils/cmsMapper";
import { createBreadcrumb } from "@utils/createBreadcrumb";
import { getCtaFields } from "@utils/getCtaFields";
import { getLocaleValue } from "@utils/getLocaleValue";
import { extractFaqItems, type JsonLdPageData } from "@utils/JsonLD/seoJsonLd";
import { linkResolver } from "@utils/linkResolver";
import { removeLang } from "@utils/pathHelper";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      webinar: string;
      lang: SiteLocale;
    };
    props: {
      seoMeta: TagFragmentType[];
      seo: SeoFieldFragmentType | null;
      content: WebinarContentFragmentType[];
      id: string;
      publishedAt: string;
      updatedAt: string;
    };
  };

  const response = await getCollection("webinar_content");

  const pathsPromises =
    response?.flatMap((item) => {
      const page = item.data;
      return page.locales.map(async (lang) => {
        const seoResCollection = await getEntry(
          "global_seo",
          `${page.id}_${lang}`,
        );
        const seoRes = seoResCollection?.data;

        const fullPath = linkResolver(page.id, lang);

        const slug = removeLang(fullPath, lang);

        return {
          params: {
            webinar: slug,
            lang: lang,
          },
          props: {
            seoMeta: seoRes?.metaTags || [],
            seo: seoRes?.seo || null,
            id: page.id,
            content: getLocaleValue(page.allContentLocales, lang, null),
            publishedAt: page.publishedAt,
            updatedAt: seoRes?.updatedAt || page.updatedAt,
          },
        };
      });
    }) || [];

  const paths = await Promise.all(pathsPromises);

  return paths.filter((path): path is PathItem => !!path.params.lang);
}

const { id, content, seo, seoMeta, publishedAt, updatedAt } = Astro.props;
const { lang } = Astro.params;

Astro.locals.lang = lang;
Astro.locals.recordId = id;

const jsonLd: JsonLdPageData = {
  pageType: ["content"],
  seo: seo || undefined,
  articleType: "TechArticle",
  publishedAt,
  updatedAt,
  faq: extractFaqItems(content ?? []),
};

// L'Hero renderizza già il proprio breadcrumb: lo mostriamo a parte solo per i
// contenuti che non iniziano con un Hero (es. contenuti editoriali).
const hasHero = (content ?? []).some(
  (block) => block.componentName === DatoBlockModel.Hero,
);
const breadcrumbItems = hasHero ? [] : createBreadcrumb(id, lang as SiteLocale);

// L'URL del video (YouTube) per il player arriva dalla CTA della
// WebinarDescription ("Vai al video"). Viene passato all'ActionCard "Webinar
// transcript" che, quando riceve un videoUrl, renderizza il VideoPlayer al
// posto della card.
const webinarDescription = (content ?? []).find(
  (block) => block.componentName === DatoBlockModel.WebinarDescription,
);
const videoText =
  webinarDescription && "text" in webinarDescription
    ? webinarDescription.text
    : null;
const { linkTo: videoUrl } = getCtaFields(
  videoText?.cta ?? null,
  lang as SiteLocale,
);
---

<Layout pageSeo={seoMeta} datePublished={publishedAt} jsonLd={jsonLd}>
  {
    breadcrumbItems.length > 0 && (
      <div class="container pt-4">
        <Breadcrumb items={breadcrumbItems} />
      </div>
    )
  }
  <PageAdapter content={content} videoUrl={videoUrl} />
</Layout>
