---
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { AllCataloguesQuery } from "@utils/query";
import type { SiteLocale } from "@graphql/types";

import type { CatalogueContentFragmentType } from "@graphql/templateFragments";
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      newsSlug: string;
      lang: SiteLocale;
    };
    props: {
      id: string;
      content: CatalogueContentFragmentType[];
    };
  };

  const response = await executeQuery(AllCataloguesQuery);

  if (!response.allCatalogues) {
    return [];
  }

  return response.allCatalogues
    ?.flatMap((newsPage) =>
      newsPage?.locales.map((lang) => ({
        params: {
          newsSlug: newsPage.allSlugLocales?.find(
            (slugLocale) => slugLocale.locale === lang,
          )?.value,
          lang: newsPage.allSlugLocales?.find(
            (slugLocale) => slugLocale.locale === lang,
          )?.locale,
        },
        props: {
          id: newsPage.id,
          content: newsPage.allContentLocales?.find(
            (contentLocale) => contentLocale.locale === lang,
          )?.value,
        },
      })),
    )
    .filter((path): path is PathItem => !!path.params.lang);
}

const { lang } = Astro.params;
const { content, id } = Astro.props;
Astro.locals.recordId = id;
---

<Layout>
  <PageAdapter content={content} />
</Layout>
