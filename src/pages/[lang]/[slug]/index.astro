---
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import {
  AllPagesSlugQuery,
  PageBySlugQuery,
  GlobalSettingsQuery,
} from "@utils/query";
import type { SiteLocale } from "@graphql/types";

import type { PageContentFragmentType } from "@graphql/templateFragments";
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      slug: string;
      lang: SiteLocale;
    };
  };

  const slugsResponse = await executeQuery(AllPagesSlugQuery);

  return slugsResponse.allPages
    .flatMap(
      (slug) =>
        slug.allSlugLocales?.map((slugLocale) => ({
          params: {
            slug: slugLocale.value,
            lang: slugLocale.locale,
          },
        })) ?? [],
    )
    .filter((path): path is PathItem => !!path.params.lang);
}

const { lang, slug } = Astro.params;

const { page } = await executeQuery(PageBySlugQuery, {
  variables: { slug: slug, locale: lang },
});

const content = page?.content as PageContentFragmentType[];

const { globalSetting } = await executeQuery(GlobalSettingsQuery, {
  variables: { locale: lang },
});
---

<Layout locale={lang} pageSeo={page?.seo}>
  <PageAdapter content={content} sitename={globalSetting?.siteName || "Home"} />
</Layout>
