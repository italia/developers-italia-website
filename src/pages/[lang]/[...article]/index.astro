---
import { SidebarLayout } from "@components/layout/SidebarLayout";
import type { TagFragmentType } from "@graphql/commonFragments";
import type { ArticleContentFragmentType } from "@graphql/templateFragments";
import type { SiteLocale } from "@graphql/types";
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import { buildFullPath } from "@utils/pathHelper";
import { AllArticlesQuery, SidebarQuery } from "@utils/query";

export async function getStaticPaths() {
  type PathItem = {
    params: {
      article: string;
      lang: SiteLocale;
    };
    props: {
      seo: TagFragmentType[];
      content: ArticleContentFragmentType;
      id: string;
    };
  };

  const response = await executeQuery(AllArticlesQuery);
  if (!response.allArticles) {
    return [];
  }

  return response.allArticles
    ?.flatMap((article) =>
      article.locales.map((lang) => ({
        params: {
          article: buildFullPath(article, lang, response.allArticles),
          lang: lang,
        },
        props: {
          id: article.id,
          content: article.allContentLocales?.find(
            (contentLocale) => contentLocale.locale === lang,
          )?.value,
        },
      })),
    )
    .filter((path): path is PathItem => !!path.params.lang);
}

const { lang } = Astro.params;
const { seo, content, id } = Astro.props;

const { sidebarForArticle } = await executeQuery(SidebarQuery, {
  variables: { locale: lang },
});

if (!sidebarForArticle) {
  return;
}

Astro.locals.recordId = id;
---

<Layout pageSeo={seo}>
  <SidebarLayout sidebar={sidebarForArticle} content={content} />
</Layout>
