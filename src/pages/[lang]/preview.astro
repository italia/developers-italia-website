---
import Layout from "@layouts/Layout.astro";
import { executeQuery } from "@lib/datocms";
import {
  GlobalSettingsQuery,
  HomepageQuery,
  PageBySlugQuery,
} from "@utils/query";
import { isDraftModeEnabled } from "@lib/draftMode";
import DraftModeQueryListener from "@components/DraftModeQueryListener.astro";
import type { PageContentFragmentType } from "@graphql/templateFragments";
import PageAdapter from "@components/cms-adapters/datocms/PageAdapter.astro";

export const prerender = false;

const draftModeEnabled = isDraftModeEnabled(Astro.cookies);
if (!draftModeEnabled) {
  return Astro.redirect("/");
}

const { slug } = Astro.params;
const { lang } = Astro.locals;

const { homepage } = await executeQuery(HomepageQuery, {
  variables: { slug: slug!, locale: lang },
  includeDrafts: true,
});

const content = homepage?.content as PageContentFragmentType[];

const { globalSetting } = await executeQuery(GlobalSettingsQuery, {
  variables: { locale: lang },
});

const redirectUrl =
  typeof lang === "string" && typeof slug === "string"
    ? `/${lang}/${slug}`
    : "/";
---

<Layout redirectUrl={redirectUrl} locale={lang} pageSeo={homepage?.seo}>
  <PageAdapter content={content} sitename={globalSetting?.siteName || "Home"} />
</Layout>
<DraftModeQueryListener
  query={PageBySlugQuery}
  variables={{ slug: slug!, locale: lang }}
/>
