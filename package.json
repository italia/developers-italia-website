{
  "name": "mywebsite",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "dotenv -c -- bash -c 'astro dev'",
    "build": "dotenv -c -- bash -c 'astro build'",
    "preview": "dotenv -c -- bash -c 'astro preview'",
    "astro": "dotenv -c -- bash -c 'astro'",
    "generate-schema": "dotenv -c -- bash -c 'gql.tada generate schema https://graphql.datocms.com --header \"X-Exclude-Invalid: true\" --header \"Authorization: $DATOCMS_API_TOKEN\"'",
    "generate-output": "gql.tada generate output",
    "tada-doctor": "gql-tada doctor",
    "tada-check": "gql-tada check",
    "prepare": "husky",
    "format": "prettier . --write --ignore-unknown"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.4.2",
    "@astrojs/vercel": "^8.2.5",
    "@datocms/astro": "^0.6.2",
    "@datocms/cda-client": "^0.2.7",
    "@datocms/cma-client": "^5.0.1",
    "astro": "^5.12.3",
    "bootstrap-italia": "^2.16.0",
    "gql.tada": "^1.8.12",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv-cli": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier-plugin-astro": "^0.14.1",
    "sass-embedded": "^1.89.2",
    "typescript": "^5.9.2"
  },
  "lint-staged": {
    "**/*": "prettier . --write --ignore-unknown"
  }
}
