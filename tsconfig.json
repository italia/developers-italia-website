{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "strict": true,
    "plugins": [
      {
        "name": "gql.tada/ts-plugin",
        "schema": "./src/graphql/schema.graphql",
        "tadaOutputLocation": "./src/graphql/graphql-env.d.ts"
      }
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  }
}
